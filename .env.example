# --- LLM providers (configure at least one) ---

# Google Gemini API key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=
# Optional Gemini model override (default: gemini-2.0-flash)
GEMINI_MODEL=

# Groq API key (https://console.groq.com/keys)
GROQ_API_KEY=
# Optional Groq model override (default: llama-3.3-70b-versatile)
GROQ_MODEL=

# NVIDIA NIM API key (https://build.nvidia.com)
NVIDIA_API_KEY=
# Optional NVIDIA base URL (default: https://integrate.api.nvidia.com/v1)
NVIDIA_BASE_URL=
# Optional NVIDIA model override (default: meta/llama-3.1-8b-instruct)
NVIDIA_MODEL=

# Default provider when the client does not specify one: gemini | groq | nvidia (default: gemini)
ARCHITECT_PROVIDER=

# --- Rate limiting (Upstash Redis; required for the POST endpoint) ---

# Upstash Redis REST URL (https://console.upstash.com)
UPSTASH_REDIS_REST_URL=
# Upstash Redis REST token
UPSTASH_REDIS_REST_TOKEN=
# Optional: max requests per window (default: 1)
ARCHITECT_RATE_LIMIT_MAX=
# Optional: rate-limit window in milliseconds (default: 60000)
ARCHITECT_RATE_LIMIT_WINDOW_MS=

# --- App ---

# URL of your main portfolio; used by the "Back to portfolio" link
NEXT_PUBLIC_PORTFOLIO_URL=
